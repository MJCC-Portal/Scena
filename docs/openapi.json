{
  "openapi": "3.0.3",
  "info": {
    "title": "Scena Edge Functions",
    "version": "1.0.0",
    "description": "Transport-level contract for Scena's 8 Supabase Edge Functions. Domain CRUD operations (src/domain/*.ts) go through the Supabase client library against RLS-protected tables, not raw HTTP routes documented here — see API_REFERENCE.md and api-inventory.json for those."
  },
  "servers": [{ "url": "{SUPABASE_URL}/functions/v1", "variables": { "SUPABASE_URL": { "default": "https://your-project.supabase.co" } } }],
  "components": {
    "schemas": {
      "ApiError": {
        "type": "object",
        "properties": {
          "error": {
            "type": "object",
            "properties": {
              "code": { "type": "string", "example": "VALIDATION_FAILED" },
              "message": { "type": "string" },
              "details": { "type": "object", "additionalProperties": true }
            },
            "required": ["code", "message"]
          }
        },
        "required": ["error"]
      }
    },
    "securitySchemes": {
      "managerBearer": { "type": "http", "scheme": "bearer", "bearerFormat": "Supabase JWT", "description": "Manager session access token." },
      "callbackSecret": { "type": "apiKey", "in": "header", "name": "x-scena-callback-secret", "description": "Shared secret for trusted backend-to-backend callers (LXC service, automation scheduler)." }
    }
  },
  "paths": {
    "/mjcc-sso-exchange": {
      "post": {
        "summary": "Exchange a KpnCompute one-time handoff code for a Scena manager session",
        "security": [],
        "requestBody": { "required": true, "content": { "application/json": { "schema": { "type": "object", "required": ["code"], "properties": { "code": { "type": "string", "minLength": 32, "maxLength": 200 } } } } } },
        "responses": {
          "200": { "description": "Session minted", "content": { "application/json": { "schema": { "type": "object", "properties": { "access_token": { "type": "string" }, "refresh_token": { "type": "string" }, "expires_in": { "type": "integer" }, "user": { "type": "object" } } } } } },
          "401": { "description": "Invalid or expired handoff", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ApiError" } } } },
          "403": { "description": "Suspended organization or disallowed role", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ApiError" } } } }
        }
      }
    },
    "/screen-register": {
      "post": {
        "summary": "Register a new kiosk device and receive a pairing code",
        "security": [],
        "requestBody": { "required": false, "content": { "application/json": { "schema": { "type": "object" } } } },
        "responses": {
          "200": { "description": "Device registered", "content": { "application/json": { "schema": { "type": "object", "properties": { "screen_id": { "type": "string", "format": "uuid" }, "device_token": { "type": "string" }, "code": { "type": "string" }, "expires_in": { "type": "integer" } } } } } }
        }
      }
    },
    "/screen-claim": {
      "post": {
        "summary": "Claim a pairing code, binding the kiosk to the caller's organization/location",
        "security": [{ "managerBearer": [] }],
        "requestBody": { "required": true, "content": { "application/json": { "schema": { "type": "object", "required": ["code", "name", "location_id"], "properties": { "code": { "type": "string", "pattern": "^[0-9]{6}$" }, "name": { "type": "string", "maxLength": 80 }, "location_id": { "type": "string", "format": "uuid" } } } } } },
        "responses": {
          "200": { "description": "Screen claimed", "content": { "application/json": { "schema": { "type": "object", "properties": { "screen": { "type": "object" } } } } } },
          "404": { "description": "Pairing code not recognized", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ApiError" } } } },
          "409": { "description": "Pairing code already consumed", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ApiError" } } } },
          "410": { "description": "Pairing code expired", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ApiError" } } } },
          "423": { "description": "Pairing code locked after too many attempts", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ApiError" } } } }
        }
      }
    },
    "/screen-credential-rotate": {
      "post": {
        "summary": "Rotate a screen's device credential",
        "security": [{ "managerBearer": [] }],
        "requestBody": { "required": true, "content": { "application/json": { "schema": { "type": "object", "required": ["screen_id"], "properties": { "screen_id": { "type": "string", "format": "uuid" } } } } } },
        "responses": {
          "200": { "description": "New credential issued", "content": { "application/json": { "schema": { "type": "object", "properties": { "screen_id": { "type": "string", "format": "uuid" }, "device_token": { "type": "string" } } } } } },
          "403": { "description": "Screen not in caller's organization, or revoked", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ApiError" } } } }
        }
      }
    },
    "/display-gateway": {
      "post": {
        "summary": "Resolve the authoritative display state for a kiosk",
        "security": [],
        "requestBody": { "required": true, "content": { "application/json": { "schema": { "type": "object", "required": ["device_token"], "properties": { "device_token": { "type": "string" } } } } } },
        "responses": {
          "200": { "description": "pending | standby | showing", "content": { "application/json": { "schema": { "type": "object", "properties": { "status": { "type": "string", "enum": ["pending", "standby", "showing"] } } } } } },
          "401": { "description": "Unrecognized or malformed device token", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ApiError" } } } },
          "403": { "description": "Screen revoked", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ApiError" } } } }
        }
      }
    },
    "/presentation-upload": {
      "post": {
        "summary": "Create or complete a presentation upload job",
        "security": [{ "managerBearer": [] }],
        "requestBody": { "required": true, "content": { "application/json": { "schema": { "oneOf": [
          { "type": "object", "required": ["action", "filename"], "properties": { "action": { "const": "create" }, "filename": { "type": "string" } } },
          { "type": "object", "required": ["action", "asset_id"], "properties": { "action": { "const": "complete" }, "asset_id": { "type": "string", "format": "uuid" } } }
        ] } } } },
        "responses": {
          "200": { "description": "Job created or completion confirmed", "content": { "application/json": { "schema": { "type": "object" } } } },
          "400": { "description": "Invalid filename or asset state", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ApiError" } } } }
        }
      }
    },
    "/presentation-callback": {
      "post": {
        "summary": "Trusted LXC-to-Scena processing-result callback",
        "security": [{ "callbackSecret": [] }],
        "requestBody": { "required": true, "content": { "application/json": { "schema": { "type": "object", "required": ["presentation_asset_id", "outcome"], "properties": { "presentation_asset_id": { "type": "string", "format": "uuid" }, "outcome": { "type": "string", "enum": ["complete", "fail"] }, "lxc_manifest_key": { "type": "string" }, "slide_count": { "type": "integer" }, "error_message": { "type": "string" } } } } } },
        "responses": {
          "200": { "description": "Asset status updated (idempotent on an already-terminal asset)", "content": { "application/json": { "schema": { "type": "object", "properties": { "asset_id": { "type": "string", "format": "uuid" }, "status": { "type": "string" }, "idempotent": { "type": "boolean" } } } } } },
          "401": { "description": "Invalid callback secret", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ApiError" } } } }
        }
      }
    },
    "/automations-run": {
      "post": {
        "summary": "Claim and execute all currently-due automations",
        "security": [{ "callbackSecret": [] }],
        "requestBody": { "required": false, "content": { "application/json": { "schema": { "type": "object" } } } },
        "responses": {
          "200": { "description": "Batch processed", "content": { "application/json": { "schema": { "type": "object", "properties": { "processed": { "type": "integer" }, "results": { "type": "array", "items": { "type": "object", "properties": { "id": { "type": "string", "format": "uuid" }, "outcome": { "type": "string", "enum": ["executed", "skipped_raced", "failed"] }, "error": { "type": "string" } } } } } } } } },
          "401": { "description": "Invalid worker secret", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ApiError" } } } }
        }
      }
    }
  }
}
