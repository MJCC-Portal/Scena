# Used only by MCP clients; do not commit real credentials.
SUPABASE_PROJECT_REF=zglbgqeccebqnijcqfkb
SUPABASE_ACCESS_TOKEN=
VITE_SUPABASE_URL=https://zglbgqeccebqnijcqfkb.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=
VITE_MJCC_PORTAL_URL=https://mjcc-managements.onrender.com

# marquee-sso Edge Function (supabase/functions/marquee-sso). Set these as
# Supabase Edge Function secrets, not in this repo. Never commit real values.
#
# KpnCompute (MJCC) API base and the shared bridge secret -- must match the
# MARQUEE_SSO_SECRET configured on the KpnCompute side exactly.
KPNCOMPUTE_API_BASE=https://mjcc-managements.onrender.com
MARQUEE_SSO_SECRET=
# Fallback source for deriving the bridge secret if MARQUEE_SSO_SECRET is
# unset (must be KpnCompute's own SUPABASE_SERVICE_KEY, not Marquee's).
MJCCV1_SERVICE_ROLE_KEY=
# This Marquee/Scena Supabase project's own service-role credentials, used to
# provision manager accounts and mint sessions.
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
# Slug of the single MJCC organization managers are provisioned into.
# Defaults to "mjcc" (matches the org seeded by 0002_marquee_manager_identity.sql).
MARQUEE_MJCC_ORG_SLUG=mjcc
# CORS allowlist for the manager-portal origin(s) calling this function.
APP_ORIGINS=

# Edge Function runtime secrets (names only). These are set as Supabase
# project secrets, not read from this file at runtime. See
# supabase/functions/mjcc-sso-exchange/.env.example and
# supabase/functions/mjcc-sso-exchange/README.md for details and for the
# unresolved KpnCompute contract TODO.
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_ANON_KEY=
MJCC_HANDOFF_VERIFY_URL=
MJCC_SERVICE_TOKEN=
MJCC_SSO_IDENTITY_EMAIL_DOMAIN=
