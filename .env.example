# mjcc-sso-exchange Edge Function secrets (set via Supabase dashboard, not here).
#
# KpnCompute (MJCC) generic SSO exchange endpoint and shared bridge secret.
# MJCC_SSO_EXCHANGE_URL must point to the generic /sso/{app}/exchange endpoint.
# MJCC_SSO_SECRET must match MARQUEE_SSO_SECRET on the KpnCompute side.
MJCC_SSO_EXCHANGE_URL=https://mjcc-managements.onrender.com/api/auth/sso/marquee/exchange
MJCC_SSO_SECRET=

# This Scena Supabase project's own service-role credentials, used to
# provision manager accounts and mint sessions.
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_ANON_KEY=

# Slug of the single MJCC organization managers are provisioned into.
# Defaults to "mjcc" (matches the org seeded by 0001_marquee_core_tenancy.sql).
ORG_SLUG=mjcc
