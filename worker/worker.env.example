SCENA_API_URL=https://YOUR_PROJECT.supabase.co/functions/v1/media-worker
SCENA_WORKER_ID=scena-media-01
SCENA_WORKER_TOKEN=replace-with-a-random-worker-token

SCENA_POLL_SECONDS=5
SCENA_LEASE_SECONDS=300
SCENA_HEARTBEAT_SECONDS=60
SCENA_REQUEST_TIMEOUT_SECONDS=60
SCENA_JOB_TIMEOUT_SECONDS=1200
SCENA_MAX_DOWNLOAD_BYTES=275000000
SCENA_CACHE_DIRECTORY=/var/cache/scena-worker
